#
# Target System -> x86
#
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

#
# 虚拟化软件支持 (ESXi)
# open-vm-tools 同样适用于 ESXi，提供时间同步、硬件信息上报等功能
#
CONFIG_PACKAGE_open-vm-tools=y
CONFIG_PACKAGE_open-vm-tools-fuse=y

#
# 网卡驱动
#

# --- Intel 系列（最常见）---
# e1000: 82540/82545，也是 ESXi E1000 虚拟网卡驱动
CONFIG_PACKAGE_kmod-e1000=y
# e1000e: 大多数 Intel 桌面/笔记本 PCIe 千兆网卡
CONFIG_PACKAGE_kmod-e1000e=y
# igb: Intel I210/I211/I350，软路由/工控机/NAS 最常见
CONFIG_PACKAGE_kmod-igb=y
# igc: Intel I225/I226 2.5GbE，N100/N5105 等新款小主机标配
CONFIG_PACKAGE_kmod-igc=y
# ixgbe: Intel 82599/X540/X550 万兆网卡，服务器常用
CONFIG_PACKAGE_kmod-ixgbe=y

# --- Realtek 系列（消费级主板最常见）---
# r8169: RTL8111/8168，绝大多数消费级主板集成网卡
CONFIG_PACKAGE_kmod-r8169=y
# r8125: RTL8125 2.5GbE，预算友好型 2.5G 网卡
CONFIG_PACKAGE_kmod-r8125=y

# --- Broadcom 系列 ---
# tg3: BCM5719/5720，服务器专用（用户指定）
CONFIG_PACKAGE_kmod-tg3=y
# bnx2x: BCM57710/57711/57712，较新的 Broadcom 服务器网卡
CONFIG_PACKAGE_kmod-bnx2x=y

# --- VMware / 虚拟化 ---
# vmxnet3: ESXi VMXNET3 高性能虚拟网卡（比 E1000 快很多）
CONFIG_PACKAGE_kmod-vmxnet3=y

# --- USB 网卡（常用于扩展网口）---
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-asix=y

#
# USB 存储支持（U盘、移动硬盘识别与挂载）
#
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-hd-idle=y

#
# IPv6 支持
#
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_ip6tables=y

#
# 内核加速与性能优化
# 注：ESXi 由宿主机管理 CPU 频率，无需 luci-app-cpufreq
#
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_irqbalance=y

#
# 科学上网插件 (主力为 OpenClash)
#
CONFIG_PACKAGE_luci-app-openclash=y

#
# 核心网络增强 (必须配置)
# 为了确保 OpenClash 能够正确接管 DNS 解析并开启 Fake-IP，需用 dnsmasq-full 替换系统默认的 dnsmasq
#
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y


#
# 常用功能插件
#
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts_aliyun=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_luci-app-openvpn=y
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_frpc=y
CONFIG_PACKAGE_luci-app-upnp=y

#
# 稳定性与自动维护
#
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-crontabs=y

#
# 网络工具与实时监控
#
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_tcpdump=y

#
# 存储管理工具
#
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-filebrowser=y

#
# 管理界面与主题
#
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

#
# 基础工具包
#
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_tar=y

#
# 固件打包设置
# ESXi 可直接导入 VMDK；实体机使用 .img.gz
#
CONFIG_TARGET_ROOTFS_PARTSIZE=500
CONFIG_VMDK_IMAGES=y
