#
# Target System -> x86
#
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

#
# 虚拟化软件支持 (ESXi)
# open-vm-tools 同样适用于 ESXi，提供时间同步、硬件信息上报等功能
#
CONFIG_PACKAGE_open-vm-tools=y
CONFIG_PACKAGE_open-vm-tools-fuse=y

#
# 网卡驱动
#

# --- 虚拟机优化网卡 ---
# vmxnet3: ESXi VMXNET3 高性能虚拟网卡（核心保留）
CONFIG_PACKAGE_kmod-vmxnet3=y
# e1000: ESXi E1000 虚拟网卡（备用兼容）
CONFIG_PACKAGE_kmod-e1000=y

# --- Intel 系列（物理机/直通网卡）---
# igb: Intel I210/I211/I350，最常见的千兆直通网卡
CONFIG_PACKAGE_kmod-igb=y
# igc: Intel I225/I226 2.5GbE，新一代软路由标配
CONFIG_PACKAGE_kmod-igc=y
# CONFIG_PACKAGE_kmod-e1000e is not set
# CONFIG_PACKAGE_kmod-ixgbe is not set

# --- Realtek 系列（常见板载/直通）---
# r8169: 大多数板载千兆网卡内核驱动
CONFIG_PACKAGE_kmod-r8169=y
# r8125: RTL8125 2.5GbE
CONFIG_PACKAGE_kmod-r8125=y
# CONFIG_PACKAGE_kmod-r8168 is not set

# --- Broadcom 系列 ---
# tg3: BCM5719/5720，服务器专用（必须保留）
CONFIG_PACKAGE_kmod-tg3=y
# CONFIG_PACKAGE_kmod-bnx2x is not set

# --- 移除不常用的 USB 网卡 ---
# CONFIG_PACKAGE_kmod-usb-net-rtl8152 is not set
# CONFIG_PACKAGE_kmod-usb-net-asix is not set

#
# 存储支持 (纯网关模式，已禁用 USB/挂载/NAS 相关插件)
#
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-usb-storage-extras is not set
# CONFIG_PACKAGE_kmod-fs-ext4 is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set
# CONFIG_PACKAGE_kmod-fs-exfat is not set
# CONFIG_PACKAGE_block-mount is not set
# CONFIG_PACKAGE_luci-app-hd-idle is not set

#
# IPv6 支持 (暂不启用)
#
# CONFIG_PACKAGE_ipv6helper is not set
# CONFIG_PACKAGE_kmod-ipt-nat6 is not set
# CONFIG_PACKAGE_ip6tables is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set

#
# 内核加速与性能优化
# 注：ESXi 由宿主机管理 CPU 频率，无需 luci-app-cpufreq
#
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_irqbalance=y

#
# 科学上网插件 (主力为 OpenClash)
#
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y

#
# 核心网络增强 (必须配置)
# 为了确保 OpenClash 能够正确接管 DNS 解析并开启 Fake-IP，需用 dnsmasq-full 替换系统默认的 dnsmasq
#
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y

#
# 常用功能插件
#
CONFIG_PACKAGE_luci-app-aliddns=y
CONFIG_PACKAGE_luci-i18n-aliddns-zh-cn=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-app-openvpn=y
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_luci-i18n-openvpn-zh-cn=y
# CONFIG_PACKAGE_luci-app-frpc is not set
# CONFIG_PACKAGE_frpc is not set
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-pushbot=y
CONFIG_PACKAGE_luci-i18n-pushbot-zh-cn=y

#
# 稳定性与自动维护
#
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-app-crontabs=y
CONFIG_PACKAGE_luci-i18n-crontabs-zh-cn=y

#
# 网络工具与实时监控
#
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-i18n-arpbind-zh-cn=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_tcpdump=y

#
# 存储管理工具
#
# CONFIG_PACKAGE_luci-app-diskman is not set
# CONFIG_PACKAGE_luci-app-filebrowser is not set

#
# 管理界面与主题
#
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

#
# 基础工具包
#
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_tar=y

# 固件分区设置
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
CONFIG_VMDK_IMAGES=y
